{# src/_includes/partials/whatsapp-button.njk #}
<div class="fixed bottom-8 right-8 z-50">
    <a href="https://wa.me/{{site.celular}}" 
       target="_blank" 
       rel="noopener noreferrer"
       class="flex items-center bg-[#1D2C4A] text-[#D3E0E7] px-6 py-3 rounded-full shadow-lg hover:bg-[#e09f3e] transition-all duration-300 group"
       aria-label="Contactar por WhatsApp">
       
        <!-- Icono con animación -->
        <div class="mr-3 group-hover:animate-bounce">
            <i class="fab fa-whatsapp text-2xl"></i>
        </div>
        
        <!-- Texto (oculto en móviles) -->
        <span class="hidden sm:inline-block font-medium">
            ¡Escribinos!
        </span>

        <!-- Burbuja con número (hover) -->
        <div class="absolute -top-10 right-0 bg-[#1D2C4A] text-[#D3E0E7] px-3 py-2 rounded-lg shadow-md opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-sm">
            !Hola! En que puedo ayudarte
            <div class="absolute w-3 h-3 bg-[#1D2C4A] rotate-45 -bottom-1 left-1/2 -translate-x-1/2"></div>
        </div>
    </a>
</div>

<style>
@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}
.animate-bounce {
    animation: bounce 1s infinite;
}
</style>